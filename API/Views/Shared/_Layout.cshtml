@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartSubscription</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
</head>
<body>

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark px-4">
        <a class="navbar-brand fw-bold" href="#">SmartSubscription</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">

                @if (HttpContextAccessor.HttpContext.Session.GetString("UserRole") == "Admin")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="AdminDashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="UserManagement" asp-action="Index">Users</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Plan" asp-action="Index">Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Subscription" asp-action="AdminIndex">Subscriptions</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Feature" asp-action="Index">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Role" asp-action="Index">Roles</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Analytics">Analytics</a>
                    </li>
                }

                @if (HttpContextAccessor.HttpContext.Session.GetString("UserRole") == "User")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="UserDashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Plan" asp-action="Index">Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Subscription" asp-action="Index">My Subscription</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payment" asp-action="Index">Payments</a>
                    </li>
                }

                @if (HttpContextAccessor.HttpContext.Session.GetString("UserRole") != null)
                {
                    <li class="nav-item ms-2">
                        <a class="btn btn-outline-light btn-sm" asp-controller="Auth" asp-action="Logout">
                            Logout
                        </a>
                    </li>
                }

            </ul>
        </div>
    </nav>

    <div class="container-fluid">
        <main class="pb-4">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
