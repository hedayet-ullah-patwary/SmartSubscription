@model BLL.DTOs.UserDTO

@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var subscriptions = ViewBag.Subscriptions as List<BLL.DTOs.SubscriptionDTO>;
    var payments      = ViewBag.Payments      as List<BLL.DTOs.PaymentDTO>;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">User Details</h2>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                <i class="fa fa-pen me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fa fa-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <!-- Profile card -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center
                                justify-content-center mb-3"
                         style="width:64px;height:64px;font-size:1.5rem">
                        @Model.Name[0].ToString().ToUpper()
                    </div>
                    <h5 class="fw-bold mb-1">@Model.Name</h5>
                    <p class="text-muted small mb-2">@Model.Email</p>
                    <span class="badge @(Model.IsActive == 1 ? "bg-success" : "bg-danger")">
                        @(Model.IsActive == 1 ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="card-footer bg-white border-0 pb-3 text-center">
                    <small class="text-muted">Role: <strong>@(ViewBag.Role ?? "—")</strong></small><br />
                    <small class="text-muted">Joined: @Model.CreatedAt.ToString("dd MMM yyyy")</small>
                </div>
            </div>
        </div>

        <!-- Subscriptions -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold">Subscriptions</div>
                <div class="card-body p-0">
                    @if (subscriptions == null || !subscriptions.Any())
                    {
                        <p class="p-3 text-muted mb-0">No subscriptions.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Plan ID</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in subscriptions)
                                {
                                    <tr>
                                        <td>@s.PlanId</td>
                                        <td>@s.StartDate.ToString("dd MMM yyyy")</td>
                                        <td>@s.EndDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge @(s.Status == "Active" ? "bg-success" : "bg-secondary")">
                                                @s.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <!-- Payments -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Payment History</div>
                <div class="card-body p-0">
                    @if (payments == null || !payments.Any())
                    {
                        <p class="p-3 text-muted mb-0">No payments.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in payments)
                                {
                                    <tr>
                                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                        <td>$@p.Amount</td>
                                        <td>@p.PaymentMethod</td>
                                        <td>@p.TransactionType</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

</div>
