@model BLL.DTOs.PlanDTO

@{
    ViewData["Title"] = "Create Plan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-0">
                <div class="card-body p-4">

                    <h3 class="fw-bold mb-4">Create New Plan</h3>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label">Plan Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Basic, Pro" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Price ($)</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="e.g. 9.99" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Duration (Days)</label>
                            <input asp-for="DurationDays" type="number" class="form-control" placeholder="e.g. 30" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">API Limit</label>
                            <input asp-for="ApiLimit" type="number" class="form-control" placeholder="e.g. 1000" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"
                                      placeholder="Plan description"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Create Plan</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>