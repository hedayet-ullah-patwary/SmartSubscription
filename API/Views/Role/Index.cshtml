@model List<BLL.DTOs.RoleDTO>

@{
    ViewData["Title"] = "Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-1">Role Management</h2>
    <p class="text-muted mb-4">Create and manage user roles</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Create form -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h5 class="mb-3">Create New Role</h5>
            <form asp-action="Create" method="post">
                <div class="row g-2">
                    <div class="col-md-8">
                        <input name="Name" class="form-control" placeholder="Role name (e.g. Admin, User)" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">Create Role</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Sort bar -->
    <div class="mb-3 d-flex gap-2">
        <span class="text-muted small align-self-center">Sort:</span>
        <a asp-action="Index" asp-route-sortBy="name"
           class="btn btn-sm @(ViewBag.SortBy == "name" ? "btn-primary" : "btn-outline-secondary")">Name</a>
        <a asp-action="Index" asp-route-sortBy="id"
           class="btn btn-sm @(ViewBag.SortBy == "id" ? "btn-primary" : "btn-outline-secondary")">ID</a>
    </div>

    <!-- List -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model == null || !Model.Any())
            {
                <p class="p-3 text-muted mb-0">No roles found.</p>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Role Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="text-muted small">@r.Id</td>
                                <td class="fw-semibold">@r.Name</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@r.Id"
                                           class="btn btn-outline-warning btn-sm" title="Edit">
                                            <i class="fa fa-pen"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" style="display:inline"
                                              onsubmit="return confirm('Delete role @r.Name?')">
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>
