@model DAL.EF.Tables.User

@{
    ViewData["Title"] = "User Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="row">

        <div class="col-md-12">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h2 class="fw-bold">
                        Welcome,
                        @Model.Name
                    </h2>

                    <p class="text-muted">
                        Smart Subscription Dashboard
                    </p>

                    <hr />

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <h5>Email</h5>
                            <p>@Model.Email</p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <h5>Email Verification</h5>

                            @if (Model.IsEmailVerified == 1)
                            {
                                <span class="badge bg-success">
                                    Verified
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Not Verified
                                </span>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <h5>Account Status</h5>

                            @if (Model.IsActive == 1)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactive
                                </span>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <h5>Joined</h5>
                            <p>
                                @Model.CreatedAt.ToShortDateString()
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ===================================== -->
    <!-- QUICK ACTIONS -->
    <!-- ===================================== -->

    <div class="row mt-4">

        <div class="col-md-3 mb-3">

            <a asp-controller="User"
               asp-action="Profile"
               class="btn btn-primary w-100 p-3">

                My Profile

            </a>

        </div>

        <div class="col-md-3 mb-3">

            <a asp-controller="Subscription"
               asp-action="Index"
               class="btn btn-success w-100 p-3">

                My Subscription

            </a>

        </div>

        <div class="col-md-3 mb-3">

            <a asp-controller="Payment"
               asp-action="Index"
               class="btn btn-warning w-100 p-3">

                Payment History

            </a>

        </div>

        <div class="col-md-3 mb-3">

            @* <a asp-controller="ApiUsage"
               asp-action="UserUsage"
               class="btn btn-dark w-100 p-3">

                API Usage

            </a> *@

        </div>

    </div>

</div>