@model DAL.EF.Tables.User

@{
    ViewData["Title"] = "User Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow border-0 mb-4">
        <div class="card-body">
            <h2 class="fw-bold">Welcome, @Model.Name</h2>
            <p class="text-muted">Smart Subscription Dashboard</p>
            <hr />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <h6 class="text-muted">Email</h6>
                    <p>@Model.Email</p>
                </div>
                <div class="col-md-6 mb-3">
                    <h6 class="text-muted">Member Since</h6>
                    <p>@Model.CreatedAt.ToShortDateString()</p>
                </div>
                <div class="col-md-6 mb-3">
                    <h6 class="text-muted">Account Status</h6>
                    @if (Model.IsActive == 1)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </div>
                <div class="col-md-6 mb-3">
                    <h6 class="text-muted">Email Verified</h6>
                    @if (Model.IsEmailVerified == 1)
                    {
                        <span class="badge bg-success">Verified</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Not Verified</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="row">
        <div class="col-md-4 mb-3">
            <a asp-controller="Plan" asp-action="Index" class="btn btn-primary w-100 p-3">
                Browse Plans
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Subscription" asp-action="Index" class="btn btn-success w-100 p-3">
                My Subscription
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Payment" asp-action="Index" class="btn btn-warning w-100 p-3">
                Payment History
            </a>
        </div>
    </div>

</div>