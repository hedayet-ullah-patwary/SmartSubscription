@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="fw-bold">
                Admin Dashboard
            </h2>
            <p class="text-muted">
                Smart Subscription SaaS System
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- ========================================= -->
    <!-- STATISTICS -->
    <!-- ========================================= -->

    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">

                    <h5>Total Revenue</h5>

                    <h2 class="text-success">
                        $@ViewBag.TotalRevenue
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">

                    <h5>Total Plans</h5>

                    <h2 class="text-primary">
                        @ViewBag.TotalPlans
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">

                    <h5>Active Users</h5>

                    <h2 class="text-warning">
                        @ViewBag.TotalUsers
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">

                    <h5>Subscriptions</h5>

                    <h2 class="text-danger">
                        @ViewBag.TotalSubscriptions
                    </h2>

                </div>
            </div>
        </div>

    </div>

    <!-- ========================================= -->
    <!-- QUICK ACTION -->
    <!-- ========================================= -->

    <div class="row mt-4">

        <div class="col-md-4 mb-3">
            <a asp-controller="User"
               asp-action="Index"
               class="btn btn-dark w-100 p-3">
                Manage Users
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Plan"
               asp-action="Index"
               class="btn btn-primary w-100 p-3">
                Manage Plans
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Analytics"
               asp-action="Index"
               class="btn btn-success w-100 p-3">
                API Analytics
            </a>
        </div>

    </div>

</div>