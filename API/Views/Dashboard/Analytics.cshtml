@{
    ViewData["Title"] = "Analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="fw-bold">Revenue Analytics</h2>
    <p class="text-muted">Financial overview of the system</p>

    <div class="row mt-3">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>Total Revenue</h5>
                    <h2 class="text-success">$@ViewBag.TotalRevenue</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>Total Subscriptions</h5>
                    <h2 class="text-primary">@ViewBag.TotalSubscriptions</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>Active Plans</h5>
                    <h2 class="text-warning">@ViewBag.TotalPlans</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Dashboard" asp-action="AdminDashboard" class="btn btn-secondary">
            Back to Dashboard
        </a>
    </div>
</div>