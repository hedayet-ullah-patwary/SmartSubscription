@model BLL.DTOs.LoginDTO

@{
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f5f7fb;
            min-height: 100vh; /* ← allows body to grow with content */
        }

        .login-container {
            min-height: 100vh;
        }

        .login-card {
            width: 100%;
            max-width: 430px;
            border: none;
            border-radius: 15px;
            box-shadow: 0px 5px 25px rgba(0,0,0,0.08);
        }

        .login-title {
            font-weight: bold;
            color: #0d6efd;
        }

        .form-control {
            height: 50px;
            border-radius: 10px;
        }

        .btn-login {
            height: 50px;
            border-radius: 10px;
            font-weight: 600;
        }

        .logo-icon {
            width: 70px;
            height: 70px;
            background: #0d6efd;
            color: white;
            border-radius: 50%;
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
        }

        .register-link {
            text-decoration: none;
            font-weight: 500;
        }

        .register-link:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="container login-container d-flex justify-content-center align-items-center">

        <div class="card login-card p-4">

            <!-- Logo -->
            <div class="text-center mb-4">
                <div class="logo-icon">
                    <i class="fa-solid fa-user-lock"></i>
                </div>

                <h2 class="login-title mt-3">
                    Smart Subscription
                </h2>

                <p class="text-muted">
                    Login to your account
                </p>
            </div>

            <!-- Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <!-- Error Message -->
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <!-- Login Form -->
            <form asp-action="Login" asp-controller="Auth" method="post">

                <!-- Email -->
                <div class="mb-3">

                    <label class="form-label">
                        Email Address
                    </label>

                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">

                    <label class="form-label">
                        Password
                    </label>

                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />

                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Remember Me -->
                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">
                        Remember Me
                    </label>
                </div>

                <!-- Login Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-login">
                        <i class="fa-solid fa-right-to-bracket"></i>
                        Login
                    </button>
                </div>
            </form>

            <!-- Footer -->
            <div class="text-center mt-4">
                <a asp-action="ForgotPassword" asp-controller="Auth" class="text-decoration-none">
                    Forgot Password?
                </a>

                <hr />

                <p>
                    Don't have an account?
                    <a asp-action="Register" asp-controller="Auth" class="register-link">
                        Register
                    </a>
                </p>
            </div>

        </div>

    </div>

    <!-- JQuery Validation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>