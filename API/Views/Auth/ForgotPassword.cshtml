@model BLL.DTOs.ForgotPasswordDTO

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3">Forgot Password</h3>
                    <p class="text-muted">Enter your email to receive a reset link.</p>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Generate Reset Link</button>
                            <a asp-action="Login" class="btn btn-outline-secondary">Back to Login</a>
                        </div>
                    </form>

                    @if (ViewBag.ShowCodeEntry == true || Context.Session.GetString("ResetCode") != null)
                    {
                        <hr />
                        <form asp-action="VerifyResetCode" method="post">
                            <div class="mb-3">
                                <label class="form-label">Enter Demo Code</label>
                                <input name="code" class="form-control" placeholder="6-digit code" />
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-success">Verify Code</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.DemoCode != null)
{
    <div class="modal fade" id="demoCodeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Demo Reset Code</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">Use this demo code to reset your password:</p>
                    <div class="alert alert-primary text-center fw-bold fs-4 mb-0">
                        @ViewBag.DemoCode
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalEl = document.getElementById("demoCodeModal");
            if (modalEl) {
                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            }
        });
    </script>
}
