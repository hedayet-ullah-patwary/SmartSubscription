@model List<BLL.DTOs.FeatureDTO>

@{
    ViewData["Title"] = "Features";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold">Features</h2>
            <p class="text-muted mb-0">Manage system features</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Add form -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h5 class="mb-3">Add New Feature</h5>
            <form asp-action="Create" method="post">
                <div class="row g-2">
                    <div class="col-md-4">
                        <input name="Name" class="form-control" placeholder="Feature name" required />
                    </div>
                    <div class="col-md-6">
                        <input name="Description" class="form-control" placeholder="Description" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Add</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Sort bar -->
    <div class="mb-3 d-flex gap-2">
        <span class="text-muted small align-self-center">Sort:</span>
        <a asp-action="Index" asp-route-sortBy="name"
           class="btn btn-sm @(ViewBag.SortBy == "name" ? "btn-primary" : "btn-outline-secondary")">Name</a>
        <a asp-action="Index" asp-route-sortBy="id"
           class="btn btn-sm @(ViewBag.SortBy == "id" ? "btn-primary" : "btn-outline-secondary")">ID</a>
    </div>

    <!-- List -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model == null || !Model.Any())
            {
                <p class="p-3 text-muted mb-0">No features found.</p>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Feature Name</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in Model)
                        {
                            <tr>
                                <td class="text-muted small">@f.Id</td>
                                <td class="fw-semibold">@f.Name</td>
                                <td class="text-muted">@f.Description</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@f.Id"
                                           class="btn btn-outline-warning btn-sm" title="Edit">
                                            <i class="fa fa-pen"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@f.Id"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Delete feature @f.Name?')" title="Delete">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>
